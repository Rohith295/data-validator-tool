<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validation Report — {{ report.file_path }}</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --green: #10b981;
            --red: #ef4444;
            --orange: #f59e0b;
            --bg: #0f172a;
            --surface: #1e293b;
            --surface-hover: #334155;
            --border: #334155;
            --text: #e2e8f0;
            --text-muted: #94a3b8;
            --text-dim: #64748b;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }

        .dashboard { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }

        /* Top bar */
        .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
        .topbar h1 { font-size: 1.3rem; font-weight: 600; }
        .topbar .meta { font-size: .8rem; color: var(--text-muted); }
        .badge { display: inline-block; padding: .25rem .75rem; border-radius: 20px; font-size: .8rem; font-weight: 600; }
        .badge-pass { background: rgba(16,185,129,.15); color: var(--green); }
        .badge-fail { background: rgba(239,68,68,.15); color: var(--red); }

        /* Stat cards row */
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
        .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem; }
        .stat-card .label { font-size: .75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: .25rem; }
        .stat-card .value { font-size: 1.6rem; font-weight: 700; }
        .stat-card .value.green { color: var(--green); }
        .stat-card .value.red { color: var(--red); }
        .stat-card .sub { font-size: .75rem; color: var(--text-dim); margin-top: .2rem; }

        /* Charts row */
        .charts { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
        .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem; }
        .chart-card h3 { font-size: .85rem; color: var(--text-muted); margin-bottom: .75rem; font-weight: 500; }
        .chart-container { position: relative; height: 220px; }

        /* History chart - full width */
        .history-section { margin-bottom: 1.5rem; }
        .history-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem; }
        .history-card h3 { font-size: .85rem; color: var(--text-muted); margin-bottom: .75rem; font-weight: 500; }
        .history-chart-container { position: relative; height: 250px; }
        .no-history { color: var(--text-dim); font-size: .85rem; padding: 2rem; text-align: center; }

        /* Validator results */
        .validators { display: flex; flex-direction: column; gap: 1rem; }
        .validator-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
        .validator-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.2rem; cursor: pointer; user-select: none; }
        .validator-header:hover { background: var(--surface-hover); }
        .validator-name { display: flex; align-items: center; gap: .6rem; font-weight: 600; font-size: .95rem; }
        .validator-name .icon { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .7rem; color: white; }
        .icon-pass { background: var(--green); }
        .icon-fail { background: var(--red); }
        .validator-meta { display: flex; gap: 1rem; font-size: .8rem; color: var(--text-muted); }
        .validator-body { display: none; border-top: 1px solid var(--border); }
        .validator-body.open { display: block; }
        .table-wrap { max-height: 350px; overflow-y: auto; }
        .table-wrap::-webkit-scrollbar { width: 6px; }
        .table-wrap::-webkit-scrollbar-track { background: var(--surface); }
        .table-wrap::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
        table { width: 100%; border-collapse: collapse; font-size: .82rem; }
        th { background: var(--bg); text-align: left; padding: .6rem 1rem; color: var(--text-muted); font-weight: 500; position: sticky; top: 0; z-index: 1; font-size: .75rem; text-transform: uppercase; letter-spacing: .03em; }
        td { padding: .55rem 1rem; border-bottom: 1px solid var(--border); }
        tr:hover td { background: rgba(255,255,255,.02); }
        td.row-num { color: var(--text-dim); font-variant-numeric: tabular-nums; }
        td.val { font-family: "SF Mono", Menlo, monospace; font-size: .8rem; color: var(--orange); }

        .footer { text-align: center; padding: 1.5rem; font-size: .75rem; color: var(--text-dim); }

        .chevron { transition: transform .2s; font-size: .8rem; color: var(--text-dim); }
        .chevron.open { transform: rotate(90deg); }

        @media (max-width: 768px) {
            .charts { grid-template-columns: 1fr; }
            .stats { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="topbar">
            <div>
                <h1>Validation Report</h1>
                <div class="meta">{{ report.file_path }} · {{ report.timestamp }}</div>
            </div>
            <span class="badge {{ 'badge-pass' if report.overall_passed else 'badge-fail' }}">
                {{ "PASSED" if report.overall_passed else "FAILED" }}
            </span>
        </div>

        <div class="stats">
            <div class="stat-card">
                <div class="label">Rows Scanned</div>
                <div class="value">{{ report.data_summary.row_count | count }}</div>
                <div class="sub">{{ report.data_summary.format | upper }} format · {{ report.data_summary.encoding_detected }}</div>
            </div>
            <div class="stat-card">
                <div class="label">Validators Run</div>
                <div class="value">{{ report.results | length }}</div>
                <div class="sub">{{ report.results | selectattr("passed") | list | length }} passed · {{ report.results | rejectattr("passed") | list | length }} failed</div>
            </div>
            <div class="stat-card">
                <div class="label">Total Errors</div>
                {% set total_errors = report.results | map(attribute='errors') | map('length') | sum %}
                <div class="value {{ 'green' if total_errors == 0 else 'red' }}">{{ total_errors }}</div>
                <div class="sub">across all validators</div>
            </div>
            <div class="stat-card">
                <div class="label">Total Time</div>
                <div class="value">{{ (report.results | sum(attribute='elapsed_ms')) | duration }}</div>
                <div class="sub">all validators combined</div>
            </div>
        </div>

        <div class="charts">
            <div class="chart-card">
                <h3>Pass / Fail Breakdown</h3>
                <div class="chart-container">
                    <canvas id="passfailChart"></canvas>
                </div>
            </div>
            <div class="chart-card">
                <h3>Errors by Validator</h3>
                <div class="chart-container">
                    <canvas id="errorsChart"></canvas>
                </div>
            </div>
        </div>

        <div class="history-section">
            <div class="history-card">
                <h3>Validation History</h3>
                <div class="history-chart-container" id="historyContainer">
                    <canvas id="historyChart"></canvas>
                </div>
            </div>
        </div>

        <div class="validators">
            {% for result in report.results %}
            <div class="validator-card">
                <div class="validator-header" onclick="toggleValidator(this)">
                    <div class="validator-name">
                        <span class="icon {{ 'icon-pass' if result.passed else 'icon-fail' }}">{{ "✓" if result.passed else "✗" }}</span>
                        {{ result.validator_name }}
                    </div>
                    <div style="display:flex;align-items:center;gap:1rem;">
                        <div class="validator-meta">
                            {% if result.errors %}<span>{{ result.errors | length }} error{{ "s" if result.errors | length != 1 }}</span>{% endif %}
                            <span>{{ result.elapsed_ms | duration }}</span>
                        </div>
                        <span class="chevron">▶</span>
                    </div>
                </div>
                {% if result.errors %}
                <div class="validator-body">
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr><th>Row</th><th>Column</th><th>Message</th><th>Value</th></tr>
                            </thead>
                            <tbody>
                                {% for err in result.errors %}
                                <tr>
                                    <td class="row-num">{{ err.row if err.row is not none else "-" }}</td>
                                    <td>{{ err.column or "-" }}</td>
                                    <td>{{ err.message }}</td>
                                    <td class="val">{{ err.value or "-" }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <div class="footer">
            data-validator · generated {{ report.timestamp }}
        </div>
    </div>

    <script>
        function toggleValidator(el) {
            const body = el.nextElementSibling;
            if (!body || !body.classList.contains('validator-body')) return;
            body.classList.toggle('open');
            el.querySelector('.chevron').classList.toggle('open');
        }

        const chartColors = {
            green: '#10b981',
            red: '#ef4444',
            orange: '#f59e0b',
            blue: '#3b82f6',
            purple: '#8b5cf6',
            cyan: '#06b6d4',
            pink: '#ec4899',
        };
        const colorList = [chartColors.blue, chartColors.orange, chartColors.purple, chartColors.cyan, chartColors.pink, chartColors.red, chartColors.green];

        Chart.defaults.color = '#94a3b8';
        Chart.defaults.borderColor = 'rgba(51,65,85,0.5)';

        // Pass/Fail donut
        const passCount = {{ report.results | selectattr("passed") | list | length }};
        const failCount = {{ report.results | rejectattr("passed") | list | length }};
        new Chart(document.getElementById('passfailChart'), {
            type: 'doughnut',
            data: {
                labels: ['Passed', 'Failed'],
                datasets: [{
                    data: [passCount, failCount],
                    backgroundColor: [chartColors.green, chartColors.red],
                    borderWidth: 0,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, pointStyle: 'circle' } }
                }
            }
        });

        // Errors by validator bar chart
        const validatorNames = [{% for r in report.results %}"{{ r.validator_name }}"{% if not loop.last %},{% endif %}{% endfor %}];
        const errorCounts = [{% for r in report.results %}{{ r.errors | length }}{% if not loop.last %},{% endif %}{% endfor %}];
        const barColors = validatorNames.map((_, i) => errorCounts[i] === 0 ? chartColors.green : colorList[i % colorList.length]);

        new Chart(document.getElementById('errorsChart'), {
            type: 'bar',
            data: {
                labels: validatorNames,
                datasets: [{
                    label: 'Errors',
                    data: errorCounts,
                    backgroundColor: barColors,
                    borderRadius: 4,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: 'rgba(51,65,85,0.3)' }, ticks: { precision: 0 } },
                    y: { grid: { display: false } }
                }
            }
        });

        // History time series
        const history = JSON.parse({{ history_json | tojson }});
        const historyContainer = document.getElementById('historyContainer');

        if (history.length > 1) {
            const labels = history.map(h => h.date);
            const totals = history.map(h => h.total_errors);
            const statuses = history.map(h => h.overall_passed);

            new Chart(document.getElementById('historyChart'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Total Errors',
                        data: totals,
                        borderColor: chartColors.orange,
                        backgroundColor: 'rgba(245,158,11,0.1)',
                        fill: true,
                        tension: 0.3,
                        pointRadius: 4,
                        pointBackgroundColor: statuses.map(s => s ? chartColors.green : chartColors.red),
                        pointBorderColor: statuses.map(s => s ? chartColors.green : chartColors.red),
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                afterLabel: function(ctx) {
                                    return statuses[ctx.dataIndex] ? 'Status: PASSED' : 'Status: FAILED';
                                }
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: 'rgba(51,65,85,0.3)' } },
                        y: { grid: { color: 'rgba(51,65,85,0.3)' }, beginAtZero: true, ticks: { precision: 0 } }
                    }
                }
            });
        } else {
            document.getElementById('historyChart').style.display = 'none';
            historyContainer.innerHTML = '<p class="no-history">Run validations multiple times with --report to see trends over time.</p>';
        }
    </script>
</body>
</html>
